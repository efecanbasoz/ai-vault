{
  "name": "ai-vault",
  "version": "1.5.0",
  "description": "AI-powered knowledge vault with multi-LLM support, Telegram bot, REST API, and CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-vault": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "cli": "tsx src/index.ts --cli-only",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "vault",
    "knowledge-base",
    "telegram-bot",
    "multi-llm",
    "claude",
    "openai",
    "gemini",
    "second-brain",
    "cli"
  ],
  "author": "Efecan Başöz <efecan@sirkhet.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "dotenv": "^16.4.7",
    "grammy": "^1.41.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.9",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "picomatch": "4.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
