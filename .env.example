# ── Interfaces ──
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
API_ENABLED=true
API_PORT=3000
API_KEY=
API_ALLOW_ANONYMOUS=false
API_MAX_BODY_BYTES=1048576
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=60
API_TRUST_PROXY_HEADERS=false
CLI_ENABLED=true

# ── Auth ──
SINGLE_USER_MODE=false
TELEGRAM_ALLOW_PUBLIC=false
TELEGRAM_ALLOWED_USERS=           # Comma-separated IDs (empty = blocked unless TELEGRAM_ALLOW_PUBLIC=true)

# ── Providers ──
DEFAULT_PROVIDER=claude-cli
CLAUDE_BIN=claude
CLAUDE_SKIP_PERMISSIONS=false
GEMINI_BIN=gemini
CODEX_BIN=codex
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4  # Any model from openrouter.ai/models
CLAUDE_MODEL=claude-sonnet-4-5-20250514    # Model for claude-api provider
OPENAI_MODEL=gpt-4o                        # Model for openai-api provider
GEMINI_MODEL=gemini-2.0-flash              # Model for gemini-api provider

# ── Vault ──
VAULT_PATH=./vault
DATA_PATH=./data

# ── Synthesis ──
SYNTHESIS_ENABLED=true
SYNTHESIS_SCHEDULE=0 9 * * 0      # Weekly Sunday 9am
SYNTHESIS_PROVIDER=claude-cli

# ── General ──
RESPONSE_TIMEOUT_MS=300000
LOG_LEVEL=info
